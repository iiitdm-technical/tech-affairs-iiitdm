{
  "name": "tech-affairs-iiitdm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "seed:org-roles": "tsx --env-file=.env.local scripts/seed-org-roles.ts",
    "cleanup:org-roles": "tsx --env-file=.env.local scripts/cleanup-old-org-roles.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node -e \"require('dotenv').config({path:'.env.local'});const pg=require('postgres');const fs=require('fs');(async()=>{const sql=pg(process.env.DATABASE_URL);const files=fs.readdirSync('./supabase/migrations').filter(f=>f.endsWith('.sql')).sort();for(const f of files){const stmts=fs.readFileSync('./supabase/migrations/'+f,'utf8').split('--> statement-breakpoint');for(const s of stmts){try{await sql.unsafe(s.trim())}catch(e){if(!e.message.includes('already exists'))console.error(f,e.message)}}}await sql.end();console.log('Done')})();\""
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.6",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.1",
    "@mui/x-data-grid": "^8.10.1",
    "@mui/x-date-pickers": "^8.10.0",
    "@supabase/supabase-js": "^2.55.0",
    "arctic": "^3.7.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.4",
    "framer-motion": "^12.23.12",
    "gsap": "^3.14.2",
    "lenis": "^1.3.8",
    "next": "^15.5.7",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "react-parallax-tilt": "^1.7.315",
    "react-tsparticles": "^2.12.2",
    "react-type-animation": "^3.2.0",
    "swiper": "^12.0.3",
    "tsparticles-slim": "^2.12.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
